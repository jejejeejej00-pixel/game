[gd_scene format=3 uid="uid://doja820l7n7nu"]

[sub_resource type="GDScript" id="GDScript_psjje"]
script/source = "extends Camera2D

@onready var spikes = $\"../../Spikes\"
@onready var player = $\"..\"

var tile_size : int = 32
var start_speed : float = 50.0
var current_speed : float = 0.0

func _ready() -> void:
	spikes.global_position.y = position.y - 8 * tile_size

func _process(delta: float) -> void:
	current_speed = start_speed + (float(player.score)/1000)
	spikes.global_position.y += current_speed * delta
	
	if spikes.global_position.y < player.global_position.y - 11 * tile_size:
		spikes.global_position.y = player.global_position.y - 10 * tile_size
		
	
"

[node name="Camera2D" type="Camera2D" unique_id=2040675805]
position = Vector2(2, 5)
process_callback = 0
limit_left = 192
limit_right = 192
position_smoothing_enabled = true
position_smoothing_speed = 10.0
drag_left_margin = 0.0
drag_top_margin = 1.0
drag_right_margin = 0.0
drag_bottom_margin = 1.0
script = SubResource("GDScript_psjje")
